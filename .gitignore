**/target/
**/*.class
**/*.jar
**/*.war

# Node / Next.js
**/node_modules/
**/.next/
**/out/
**/dist/
**/build/

# Python
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.venv/
**/venv/
**/*.egg-info/

# ─── Environment & Secrets ───────────────────
**/.env
**/.env.*
!**/.env.example

